{
  "schema": "starwork.pack.v0.1",
  "id": "content-creator",
  "version": "0.1.0",
  "compatible_core": "0.1",
  "supports_workspace_types": ["project", "single-light", "single-matter"],
  "requires_capabilities": [],
  "roles": {
    "account_profile": { "kind": "strategy" },
    "ideas": { "kind": "pipeline" },
    "materials": { "kind": "source" },
    "analysis": { "kind": "research" },
    "calendar": { "kind": "planning" },
    "drafts": { "kind": "work_in_progress" },
    "published": { "kind": "formal_source" },
    "review": { "kind": "learning_loop" },
    "feedback": { "kind": "source" },
    "commercial": { "kind": "opportunity" },
    "style": { "kind": "reference" }
  },
  "flow": ["account_profile", "ideas", "materials", "drafts", "published", "review"],
  "rules": [
    { "id": "overview", "slot": "pack.content-creator.overview" },
    { "id": "workflow", "slot": "pack.content-creator.workflow" },
    { "id": "file-boundaries", "slot": "pack.content-creator.file_boundaries" },
    { "id": "review", "slot": "pack.content-creator.review" }
  ],
  "templates": [
    { "id": "content-brief" },
    { "id": "publish-record" },
    { "id": "weekly-review" }
  ],
  "seed": [
    { "id": "account-profile", "role": "account_profile" },
    { "id": "ideas", "role": "ideas" },
    { "id": "materials", "role": "materials" },
    { "id": "drafts", "role": "drafts" },
    { "id": "published", "role": "published" },
    { "id": "review", "role": "review" }
  ]
}
