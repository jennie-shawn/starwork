{
  "schema": "starwork.pack.v0.1",
  "id": "general",
  "name": "通用工作 Pack",
  "version": "0.1.0",
  "compatible_core": "0.1",
  "supports_workspace_types": ["single-light", "single-matter"],
  "requires_capabilities": [],
  "paths": {
    "references": "references/",
    "drafts": "outputs/drafts/",
    "final": "outputs/final/"
  },
  "flow": ["references", "drafts", "final"],
  "overrides": {
    "formal_source": "outputs/final/",
    "business_work_area": "outputs/drafts/"
  },
  "rules": [
    {
      "slot": "pack.overview",
      "from": "rules/overview.md"
    },
    {
      "slot": "pack.workflow",
      "from": "rules/workflow.md"
    }
  ],
  "templates": [],
  "seed": []
}
